# =============================================================================
# UPI Flow Payment - Root .gitignore
# Monorepo-focused .gitignore for Node.js/JS projects.
# Excludes: dependencies, build artifacts, env/secrets, caches, logs,
# IDE/editor files, OS-specific files, and local DB/test artifacts.
# =============================================================================

# =============================================================================
# NODE.JS & PACKAGE MANAGERS
# =============================================================================

# Dependencies
node_modules/
node_modules.old/
*.old/

# Package manager caches/stores
.npm/
.npm-cache/
npm-cache/
.yarn/
.yarn/cache/
.pnpm-store/
.pnpm-debug.log*

# TypeScript / tooling
*.tsbuildinfo

# =============================================================================
# ENVIRONMENT VARIABLES / SECRETS (MOST IMPORTANT)
# =============================================================================

# Never commit real environment files.
.env
.env.*

# Common local env variants.
.env.local
.env.development.local
.env.test.local
.env.production.local

# Explicitly cover any other local/secret env suffixes.
.env.*.local

# Optional: keep example files tracked.
# !.env.example
# !.env.*.example

# =============================================================================
# CREDENTIALS / PRIVATE KEYS / TOKENS (DEFENSIVE)
# =============================================================================

# Generic key material.
*.key
*.pem
*.crt
*.cer
*.pfx

# Common credential/secret filenames (covers accidental commits).
API_KEY*
SECRET*
JWT*
TOKEN*
PRIVATE_KEY*
RAZORPAY*

# JSON credential files (common in local dev).
credentials*.json

# =============================================================================
# BUILD OUTPUTS & COMPILATION
# =============================================================================

# General
dist/
build/

# Vite
.vite/

# Next.js (if used anywhere in the monorepo)
.next/
out/

# Nuxt (if used anywhere in the monorepo)
.nuxt/
.nuxt/
.output/

# Parcel
.parcel-cache/

# Compiled/local bundles
*.local

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================

logs/
*.log

# Runtime/temp folders
temp/
tmp/

# Uploads/data folders (commonly contain local artifacts)
uploads/
data/

# Caches
.cache/

# =============================================================================
# TESTING & COVERAGE
# =============================================================================

coverage/
*.lcov
.nyc_output/

# =============================================================================
# DATABASE & LOCAL STATE ARTIFACTS
# =============================================================================

# SQLite / local DB
*.db
*.sqlite
*.sqlite3

# Local dumps / backups / exports
*.dump
*.dmp
*.backup
*.bak

# =============================================================================
# EDITOR / IDE / WORKSPACE FILES
# =============================================================================

# VS Code
.vscode/
!.vscode/extensions.json

# IntelliJ/WebStorm
.idea/
*.iml
*.iws

# Visual Studio
*.sln
*.suo
*.ntvs*
*.njsproj

# Sublime
*.sublime-project
*.sublime-workspace

# Vim/Emacs swap files
*.swp
*.swo
*~

# =============================================================================
# OS-SPECIFIC FILES
# =============================================================================

Thumbs.db
Thumbs.db:encryptable
.DS_Store
.DS_Store?
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# AI / LLM WORKING DIRS (IF PRESENT)
# =============================================================================

.qwen/
.ai/
.cursor/
*.ai-context*

# =============================================================================
# DOCKER / OTHER
# =============================================================================

.docker/

# =============================================================================
# SUBMODULES
# =============================================================================

.gitmodules

