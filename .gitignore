# =============================================================================
# UPI Flow Payment - Root .gitignore
# Comprehensive gitignore for the entire monorepo project
# =============================================================================

# =============================================================================
# NODE.JS & NPM
# =============================================================================
# Dependencies
node_modules/
npm-cache/
.pnp
.pnp.js

# Package lock files (optional - uncomment if you want to ignore)
# package-lock.json
# backend/package-lock.json
# frontend/package-lock.json
# checkout-widget/backend/package-lock.json

# npm log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Never commit actual environment variables
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Environment examples (keep .env.example for reference)
#backend/.env.local (keep .env.example only)

# =============================================================================
# BUILD OUTPUTS & COMPILATION
# =============================================================================
# Vite/React build outputs
dist/
dist-ssr/
build/
*.local

# Parcel cache
.parcel-cache/

# TypeScript build info
*.tsbuildinfo

# Next.js (if used)
.next/
out/

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================
# Log files
logs/
*.log
server_output.log

# Temporary/runtime directories
temp/
tmp/
uploads/
data/

# Cache directories
.cache/

# =============================================================================
# EDITOR & IDE
# =============================================================================
# VS Code
.vscode/*
!.vscode/extensions.json
.vscode/

# IntelliJ / WebStorm
.idea/
*.iml
*.iws
out/

# Atom
.bin/
.symbols

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache

# Emacs
*~/
\#*
.\#*

# Vim
*.swp
*.swo
*~
.Session.vim
.netrwhist

# Kate
.*.kate

# =============================================================================
# OPERATING SYSTEM FILES
# =============================================================================
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
.DS_Store
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
.*.un~
Trash-*

# =============================================================================
# DATABASE & STATE FILES
# =============================================================================
# SQLite
*.db
*.sqlite
*.sqlite3

# MongoDB data (local)
# (if using local MongoDB data directory)
# data/mongodb/
# *.mongodata

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
coverage/
*.lcov
.nyc_output/

# Jest
coverage/
*.test.js

# Mocha
mochawesome-report/
mochawesome-results/

# =============================================================================
# AI / LLM WORKING FILES
# =============================================================================
.qwen/
.ai/
.cursor/
*.ai-context*

# =============================================================================
# WINDOWS BATCH SCRIPTS (Optional - keep if needed)
# =============================================================================
# Uncomment if you don't want to track Windows scripts
# *.bat
# *.cmd

# =============================================================================
# MISCELLANEOUS
# =============================================================================
# PDF generated files
*.pdf

# Credentials file (if exists)
credentials.json

# Docker
.docker/

# =============================================================================
# SUBMODULES (if using git submodules)
# =============================================================================
.gitmodules

# =============================================================================
# SKIP WORKING TREE UPDATES
# =============================================================================
# Uncomment if you have long-running operations and want to skip
# skip-worktree.txt
