# API Configuration
API_BASE_URL=http://localhost:3000

# Security (for production)
# Set a proper JWT secret for development
JWT_SECRET=dev_jwt_secret_key_2026_do_not_use_in_production
ENCRYPTION_KEY=dev_encryption_key_2026_do_not_use_in_production

# Mock Auth for Development (set to 'true' to bypass JWT validation)
USE_MOCK_AUTH=true

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Logging
LOG_LEVEL=debug

# AI Configuration (OpenAI)
# Set to 'mock' or 'demo' to use the built-in mock AI (no API key needed)
# Set to your actual OpenAI API key to use real AI features
OPENAI_API_KEY=mock
OPENAI_MODEL=gpt-4o-mini

