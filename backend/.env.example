NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=payment_app
FRONTEND_DIST_PATH=../frontend/dist
DEMO_USER_NAME=Demo User
DEMO_USER_EMAIL=demo@payapp.local
ENCRYPTION_KEY=replace_with_a_real_key
PAYMENT_DISCLAIMER=RBI-regulated payment service. All transactions are encrypted with 256-bit encryption.

# Razorpay credentials (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# AI Layer (optional — Phase 1: form generator + merchant assistant)
# Phase 2: analytics insights + support bot
# Leave blank to disable AI features without breaking anything
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
